+## Resolve elimination chains after a clean mode swap.
+##
+## Called by _on_hand_swapped signal. Checks for matches first.
+## If no match found, still consumes a swap (wasted move) with shake animation.
+## When matches found, runs cascade loop with VFX between waves.
+func _resolve_clean_chain() -> void:
+	var gs = NinKingGameState
+	if gs.current_state != NinKingGameState.State.PLAYING:
+		return
+	if gs.game_mode != "clean":
+		return
+
+	# Check if swap formed any match — if not, wasted swap with shake
+	var first_wave: Dictionary = CleanController.prepare_chain_wave(gs, 0)
+	if first_wave.is_empty():
+		# CL18: no-match anim — shake card grid + UI_ERROR sfx
+		GlobalTweens.shake_node(ui.card_grid, 0.5, 0.1)
+		GlobalTweens.play_sfx(SB.UI_ERROR)
+		gs.swaps_remaining -= 1
+		gs.emit_swaps_changed()
+		gs.hand_updated.emit(gs.hand)
+		if gs.swaps_remaining <= 0 and gs.current_score < gs.target_score:
+			gs._transition_to(NinKingGameState.State.GAME_OVER)
+		return
+
+	# Enter SCORING state to lock player input
+	gs._transition_to(NinKingGameState.State.SCORING)
+
+	var chains: Array[Dictionary] = []
+	var chain_level: int = 0
+	# CL18: viewport center for particle bursts
+	var vp_center := get_viewport_rect().size * 0.5
+
+	# ══ Process first wave with animation ══
+	chain_level += 1
+	first_wave["chain_level"] = chain_level
+	chains.append(first_wave)
+
+	# CL18: burst manga_burst particles at grid center
+	GlobalTweens.burst_particles(vp_center, "manga_burst")
+	GlobalTweens.play_sfx(SB.SWAP)
+	# CL18: screen shake for chain feel
+	GlobalTweens.screen_shake(0.1, 0.06)
+	# Apply wave data mutation
+	CleanController.apply_chain_wave(gs, first_wave)
+
+	# Refresh visual hand after data mutation
+	gs.hand_updated.emit(gs.hand)
+
+	# Brief wait for VFX to settle
+	await get_tree().create_timer(0.25).timeout
+	if not is_instance_valid(gs) or not is_instance_valid(self):
+		return
+
+	# ══ Chain loop for subsequent waves ══
+	while true:
+		var wave: Dictionary = CleanController.prepare_chain_wave(gs, chain_level)
+		if wave.is_empty():
+			break
+
+		chain_level += 1
+		wave["chain_level"] = chain_level
+		chains.append(wave)
+
+		# CL18: stronger burst + shake for chain waves
+		GlobalTweens.burst_particles(vp_center, "manga_burst")
+		GlobalTweens.play_sfx(SB.SWAP)
+		if chain_level >= 3:
+			GlobalTweens.screen_shake(0.2, 0.12)
+			GlobalTweens.do_hit_stop(0.08, 0.04)
+		else:
+			GlobalTweens.screen_shake(0.15, 0.08)
+
+		CleanController.apply_chain_wave(gs, wave)
+		gs.hand_updated.emit(gs.hand)
+
+		# VFX delay
+		await get_tree().create_timer(0.25).timeout
+		if not is_instance_valid(gs) or not is_instance_valid(self):
+			return
+
+		# Hard cap
+		if chain_level >= 10:
+			push_warning("GameManager: clean chain reached hard cap of 10 waves")
+			break
+
+	# ── CL13: Compute clean score with ninja integration ──
+	var clean_result: Dictionary = ScoreCalculator.calculate_clean(
+		gs.hand, chains, gs.owned_ninjas, gs.gold
+	)
+	var swap_score: int = clean_result.get("swap_score", 0)
+
+	# CL18: score popup at end of chain
+	if chain_level > 0 and swap_score > 0:
+		_show_clean_score_popup(swap_score, chain_level)
+
+	# Apply gold_on_swap (if any ninja gives gold per swap)
+	var gold_earned: int = clean_result.get("gold_on_swap", 0)
+	if gold_earned > 0:
+		gs.gold += gold_earned
+		gs.gold_changed.emit(gs.gold)
+
+	# Apply extra_swaps / only_one_swap
+	var extra: int = clean_result.get("extra_swaps", 0)
