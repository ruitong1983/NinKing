#!/bin/sh
# ═══════════════════════════════════════════════════════
# Pre-commit hook: sync ninja-card-viewer.html on data change
# Runs all extract scripts to keep the HTML viewer up-to-date.
# ═══════════════════════════════════════════════════════
# Auto-install:  sh tools/install-hooks.sh
# Manual install: cp tools/pre-commit .git/hooks/pre-commit
# ═══════════════════════════════════════════════════════

# Prefer python over python3 (Windows Store python3 stub breaks in Git Bash)
PYTHON="python"
command -v "$PYTHON" >/dev/null 2>&1 || PYTHON="python3"

HTML="docs/ninking/ninja_card_viewer.html"
EXTRACTORS="tools/extract_ninja_data.py tools/extract_xi_data.py tools/tscn_parser.py"
INJECTOR="tools/inject_recent_updates.py"

for SCRIPT in $EXTRACTORS; do
  echo "  ⟳ $(basename "$SCRIPT" .py)..."
  "$PYTHON" "$SCRIPT" "$HTML" || { echo "  ⚠️  $SCRIPT failed"; exit 1; }
done

echo "  ⟳ 最近更新..."
"$PYTHON" "$INJECTOR" "$HTML"

# Only stage HTML if changed
if git diff --quiet "$HTML"; then
  echo "  ✓ HTML 无变更"
else
  git add "$HTML"
  echo "  ✓ HTML 已更新并暂存"
fi
